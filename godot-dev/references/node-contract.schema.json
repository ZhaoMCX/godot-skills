{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "node-contract.schema.json",
  "title": "Godot Node Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "contract_id",
    "kind",
    "type_name",
    "engine_version",
    "engine_build_hash",
    "scope",
    "source_path",
    "source_hash",
    "inheritance_chain",
    "base_contract_hashes",
    "context_requirements",
    "authoring_mode",
    "properties",
    "serialization",
    "signals",
    "path_constraints",
    "child_constraints",
    "lifecycle_constraints",
    "evidence",
    "validation",
    "status",
    "contract_hash"
  ],
  "properties": {
    "contract_version": { "const": 2 },
    "contract_id": { "type": "string", "minLength": 1 },
    "kind": { "const": "node" },
    "type_name": { "type": "string", "minLength": 1 },
    "engine_version": { "type": "string", "pattern": "^4\\.7\\.1$" },
    "engine_build_hash": { "type": "string", "minLength": 1 },
    "scope": { "enum": ["builtin", "third-party", "project"] },
    "source_path": { "type": "string" },
    "source_hash": { "type": "string" },
    "package_id": { "type": "string" },
    "package_version": { "type": "string" },
    "inheritance_chain": { "type": "array", "items": { "type": "string" } },
    "base_contract_hashes": { "type": "object", "additionalProperties": { "type": "string" } },
    "context_requirements": { "$ref": "resource-contract.schema.json#/$defs/contextRequirements" },
    "authoring_mode": { "enum": ["direct_text", "generated_structure", "scene_template", "resource_saver_only", "reference_only"] },
    "properties": { "$ref": "resource-contract.schema.json#/$defs/propertyList" },
    "serialization": { "$ref": "resource-contract.schema.json#/$defs/serialization" },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "arguments"],
        "properties": {
          "name": { "type": "string" },
          "arguments": { "type": "array" }
        }
      }
    },
    "path_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["property", "resolution", "target_type"],
        "properties": {
          "property": { "type": "string", "minLength": 1 },
          "resolution": { "enum": ["scene_tree", "runtime", "external"] },
          "target_type": { "type": "string" }
        }
      }
    },
    "child_constraints": { "type": "array", "items": { "type": "string" } },
    "lifecycle_constraints": { "type": "array", "items": { "type": "string" } },
    "evidence": { "$ref": "resource-contract.schema.json#/$defs/evidence" },
    "validation": { "$ref": "resource-contract.schema.json#/$defs/validation" },
    "status": { "enum": ["cataloged", "validated", "stale", "reference_only"] },
    "contract_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
