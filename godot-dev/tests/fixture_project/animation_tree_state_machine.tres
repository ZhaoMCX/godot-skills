[gd_resource type="AnimationNodeStateMachine" load_steps=5 format=3]

[sub_resource type="AnimationNodeAnimation" id="AnimationNodeAnimation_idle"]
animation = &"idle"

[sub_resource type="AnimationNodeAnimation" id="AnimationNodeAnimation_run"]
animation = &"run"

[sub_resource type="AnimationNodeStateMachineTransition" id="Transition_idle_run"]
xfade_time = 0.1

[sub_resource type="AnimationNodeStateMachineTransition" id="Transition_run_idle"]
xfade_time = 0.1

[resource]
states/idle/node = SubResource("AnimationNodeAnimation_idle")
states/idle/position = Vector2(240, 100)
states/run/node = SubResource("AnimationNodeAnimation_run")
states/run/position = Vector2(440, 100)
transitions = [&"idle", &"run", SubResource("Transition_idle_run"), &"run", &"idle", SubResource("Transition_run_idle")]
